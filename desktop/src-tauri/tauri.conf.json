{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "clawleash",
  "version": "0.1.0",
  "identifier": "com.clawleash.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "toast",
        "url": "index.html",
        "title": "clawleash",
        "width": 340,
        "height": 168,
        "minWidth": 340,
        "minHeight": 168,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false,
        "focus": false,
        "windowEffects": {
          "effects": ["popover"],
          "state": "active",
          "radius": 20
        }
      },
      {
        "label": "qr",
        "url": "qr.html",
        "title": "clawleash — phone link",
        "width": 300,
        "height": 392,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false,
        "center": true,
        "windowEffects": {
          "effects": ["popover"],
          "state": "active",
          "radius": 22
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
